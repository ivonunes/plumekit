{
  "comments": {
    "blockComment": ["@comment {", "}"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["<", ">"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" },
    { "open": "<", "close": ">" }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"],
    ["<", ">"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(@(?:if|for|component|content|slot|style|script|navigation|comment)\\b.*\\{|\\}\\s*else(?:\\s+if\\b.*)?\\{|.*\\{\\s*)$",
    "decreaseIndentPattern": "^\\s*\\}"
  }
}
