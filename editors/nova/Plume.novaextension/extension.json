{
  "identifier": "uk.ivonunes.plume",
  "name": "Plume",
  "organization": "Ivo Nunes",
  "version": "2.0.2",
  "description": "Language support for Plume templates.",
  "icon": "Images/extension.png",
  "categories": [
    "languages",
    "completions",
    "formatters",
    "issues"
  ],
  "bugs": "https://github.com/ivonunes/plumekit/issues",
  "repository": "https://github.com/ivonunes/plumekit",
  "license": "MIT",
  "min_runtime": "10.0",
  "main": "main.js",
  "activationEvents": [
    "onLanguage:plume",
    "onCommand:plume.restartLanguageServer",
    "onCommand:plume.checkTheme"
  ],
  "entitlements": {
    "process": true,
    "filesystem": "readonly"
  },
  "config": {
    "plume.toolPath": {
      "title": "Plume Tool Path",
      "type": "string",
      "default": "",
      "description": "Path to the plumekit CLI. Leave empty to use ./plumekit in the workspace, then plumekit on PATH."
    }
  },
  "commands": {
    "extensions": [
      {
        "title": "Restart Language Server",
        "command": "plume.restartLanguageServer"
      },
      {
        "title": "Check Templates",
        "command": "plume.checkTheme"
      },
      { "title": "PlumeKit: Dev Server (watch)", "command": "plumekit.dev" },
      { "title": "PlumeKit: Serve", "command": "plumekit.serve" },
      { "title": "PlumeKit: Build", "command": "plumekit.build" },
      { "title": "PlumeKit: Deploy", "command": "plumekit.deploy" },
      { "title": "PlumeKit: Migrate", "command": "plumekit.migrate" },
      { "title": "PlumeKit: Show Routes", "command": "plumekit.routes" },
      { "title": "PlumeKit: Doctor", "command": "plumekit.doctor" },
      { "title": "PlumeKit: Generate…", "command": "plumekit.generate" }
    ]
  }
}
